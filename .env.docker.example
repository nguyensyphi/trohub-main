# Sao chép thành .env.docker rồi chỉnh giá trị (đặc biệt mật khẩu & JWT).
# Chạy: docker compose --env-file .env.docker up --build -d

# --- PostgreSQL (service postgres) ---
POSTGRES_DB=phongtroxanh
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# --- Cổng publish ra máy host ---
API_PORT=5001
WEB_PORT=8080

# --- Build frontend (URL mà trình duyệt gọi API; khi có domain thật hãy đổi) ---
VITE_SERVER_URL=http://localhost:5001/api/v1
VITE_CLIENT_GG_ID=
VITE_DROPBOX_API=
VITE_EXCHANGERATE_API=
VITE_PAYPAL_CLIENT_ID=
VITE_PRICE_OF_POST_PER_DAY=

# --- Backend (Express) — bổ sung từ server/.env.example ---
PORT=5001
NODE_ENV=production
CLIENT_URL=http://localhost:8080
CLIENT_PAYMENT_RETURN_URL=http://localhost:8080/thanh-toan/
JWT_SECRET=thay-bang-chuoi-bi-mat-dai

DB_DIALECT=postgres
DB_SSL=false

# Các biến dưới đây được compose ghi đè khi trỏ vào container postgres (không cần sửa nếu dùng stack mặc định)
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=phongtroxanh
# DB_USER=postgres
# DB_PASSWORD=changeme

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

VNP_TMNCODE=
VNP_HASHSECRET=
VNP_URL=
VNP_RETURN_URL=
VNP_BANKCODE=

MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_PARTNER_NAME=
MOMO_STORE_ID=
MOMO_ENDPOINT=
MOMO_REDIRECT_URL=
MOMO_IPN_URL=

TWILLO_ACCOUNT_SSD=
TWILLO_AUTH_TOKEN=
TWILLO_SERVICE_SID=
