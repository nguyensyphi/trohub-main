FROM node:20-alpine AS build

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci

COPY . .

ARG VITE_SERVER_URL=http://localhost:5001/api/v1
ARG VITE_CLIENT_GG_ID=
ARG VITE_DROPBOX_API=
ARG VITE_EXCHANGERATE_API=
ARG VITE_PAYPAL_CLIENT_ID=
ARG VITE_PRICE_OF_POST_PER_DAY=

ENV VITE_SERVER_URL=$VITE_SERVER_URL
ENV VITE_CLIENT_GG_ID=$VITE_CLIENT_GG_ID
ENV VITE_DROPBOX_API=$VITE_DROPBOX_API
ENV VITE_EXCHANGERATE_API=$VITE_EXCHANGERATE_API
ENV VITE_PAYPAL_CLIENT_ID=$VITE_PAYPAL_CLIENT_ID
ENV VITE_PRICE_OF_POST_PER_DAY=$VITE_PRICE_OF_POST_PER_DAY

RUN npm run build

FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
